---
import SocialLinks from './SocialLinks.astro';
const today = new Date();
---

<footer class="max-w-3xl mx-auto w-full px-4 mt-auto">
	<hr class="border-border" aria-hidden="true">
	<div class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4">
		<div class="flex gap-1">
			<SocialLinks />
		</div>
		<div class="my-2 whitespace-nowrap opacity-70">
			&copy; {today.getFullYear()} Brendan Asselstine
		</div>
	</div>
</footer>
